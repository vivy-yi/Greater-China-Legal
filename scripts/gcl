#!/usr/bin/env python3
"""
gcl — Greater China Legal CLI

用法：
  gcl init [--force]        初始化配置
  gcl law <法条名>          查法条文本
  gcl cases <关键词>        查案例
  gcl verify <法条名>       验证法条效力
  gcl search <关键词>       通用搜索
  gcl mcp-config            输出 MCP server 配置
  gcl version               版本信息
"""

import argparse
import json
import os
import re
import subprocess
import sys
import urllib.parse
import urllib.request
from pathlib import Path

VERSION = "0.2.0"
CONFIG_DIR = Path.home() / ".gcl"
CONFIG_FILE = CONFIG_DIR / "config.json"

DEFAULT_CONFIG = {
    "data_sources": {
        "npc_api": {"enabled": True},
        "web_search": {"enabled": True},
        "yuandian_mcp": {"enabled": False, "api_key": ""},
        "pkulaw_mcp": {"enabled": False, "api_key": ""},
    },
    "default_source": "auto",
    "output_format": "markdown",
}


def load_config():
    if CONFIG_FILE.exists():
        try:
            cfg = json.loads(CONFIG_FILE.read_text())
            for k, v in DEFAULT_CONFIG.items():
                cfg.setdefault(k, v)
            return cfg
        except Exception:
            pass
    return dict(DEFAULT_CONFIG)


def save_config(cfg):
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    CONFIG_FILE.write_text(json.dumps(cfg, ensure_ascii=False, indent=2))


from typing import Optional


def url_fetch(url: str) -> Optional[str]:
    """Fetch a URL with timeout and browser-like UA."""
    try:
        req = urllib.request.Request(
            url,
            headers={"User-Agent": "Mozilla/5.0 (Macintosh; Intel Mac OS X 10_15_7)"},
        )
        with urllib.request.urlopen(req, timeout=10) as r:
            return r.read().decode("utf-8", errors="replace")
    except Exception:
        return None


def web_search(query: str, limit: int = 5) -> list[dict]:
    """Web search via multiple strategies."""
    results = []
    encoded = urllib.parse.quote(query)

    # Strategy 1: Try direct NPC / legal database access
    # (most reliable for Chinese legal queries, no search engine needed)
    try:
        # Try to access the law directly by name from known sites
        sites_to_try = [
            f"https://flk.npc.gov.cn/law?q={encoded}",
            f"https://www.gov.cn/search?q={encoded}",
        ]
        have_data = False
        for site_url in sites_to_try:
            try:
                req = urllib.request.Request(site_url, headers={"User-Agent": "Mozilla/5.0"})
                with urllib.request.urlopen(req, timeout=5) as r:
                    body = r.read().decode("utf-8", errors="replace")
                    if len(body) > 5000 and "404" not in body[:100]:
                        results.append({
                            "title": f"查询结果: {urllib.parse.unquote(encoded)[:50]}",
                            "url": site_url,
                        })
                        have_data = True
                        break
            except Exception:
                continue
    except Exception:
        pass

    # Strategy 2: Try Brave Search API (free tier, 2000 queries/month)
    # Requires BRAVE_API_KEY env var or config. If not set, skip.
    try:
        import os as _os
        brave_key = _os.environ.get("BRAVE_API_KEY") or None
        if brave_key:
            import json as _json
            import ssl as _ssl
            ctx = _ssl.create_default_context()
            url = f"https://api.search.brave.com/res/v1/web/search?q={encoded}&count={limit}"
            req = urllib.request.Request(url, headers={"Accept": "application/json", "X-Subscription-Token": brave_key})
            with urllib.request.urlopen(req, timeout=8, context=ctx) as r:
                data = _json.loads(r.read())
                for item in (data.get("web", {}) or {}).get("results", []):
                    results.append({"title": item.get("title", ""), "url": item.get("url", "")})
                    if len(results) >= limit:
                        break
    except Exception:
        pass

    return results


def print_section(heading: str, items: list[dict], tag: str):
    """Print a section of results."""
    if not items:
        return
    print(f"─── {heading} ───\n")
    for item in items:
        print(f"🔗 {item['title']}")
        print(f"   {item['url']}")
        print(f"   来源: [{tag}]\n")


