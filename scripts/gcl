def cmd_sources():
    """列出所有已配置的数据源"""
    print(f"─── GCL 数据源清单 ───\n")
    print(f"{'代号':<10} {'名称':<25} {'类型':<14} {'覆盖':<30} {'免费'}")
    print("─" * 90)
    for k, v in DATA_SOURCES.items():
        free = "✅" if v.get("free") else "❌"
        print(f"{k:<10} {v['name']:<25} {v['type']:<14} {v['coverage']:<30} {free}")
    print()
    print(f"完整说明: plugins/shared/gcl-data-service/references/data-sources.md")
    print(f"配置: ~/.gcl/config.json")


def cmd_law(queries: list[str]):
    query = " ".join(queries)
    print(f"─── 法条查询: {query} ───\n")

    # Strategy 1: Try NPC database (free government source)
    # The NPC database is a SPA; direct API calls may not work.
    # Try known legal data sites directly.
    site_queries = [
        f"site:flk.npc.gov.cn {query}",
        f"site:gov.cn {query} 条文",
        f"{query} 条文 民法典",
    ]
    found = False
    for sq in site_queries:
        items = web_search(sq, limit=3)
        if items:
            print_section("国家法律法规数据库", items, "GOV")
            found = True
            break

    if not found:
        print(f"""⚠️ 外部数据源未返回结果。
   查询内容: {query}
   建议:
   • 直接访问 flk.npc.gov.cn（国家法律法规数据库）
   • 设置 BRAVE_API_KEY 环境变量启用 Brave Search
     export BRAVE_API_KEY=your_key
     免费注册: https://api.search.brave.com/app/dashboard
   • 运行 gcl init 重新配置
""")


# ── 案例查询 ─────────────────────────────────────────

def cmd_cases(queries: list[str]):
    query = " ".join(queries)
    print(f"─── 案例查询: {query} ───\n")

    items = web_search(f"{query} 裁判文书 案号", limit=5)
    if items:
        print_section("裁判文书 / 案例检索", items, "web")
    else:
        print("""⚠️ 未找到相关案例。
   建议到 wenshu.court.gov.cn 或 pkulaw.com 检索。
   来源: [model] — 须核实
""")

# ── 法条效力验证 ─────────────────────────────────────

def cmd_verify(queries: list[str]):
    query = " ".join(queries)
    print(f"─── 效力验证: {query} ───\n")

    items = web_search(f"{query} 修订 废止 现行有效", limit=5)
    if items:
        print_section("修订/废止公告检索", items, "web")
        print("💡 未发现修订/废止公告可视为现行有效，建议到 NPC 数据库确认。")
    else:
        print("""⚠️ 未找到相关公告。
   建议直接访问 flk.npc.gov.cn 查询该法条的现行状态。
   来源: [model] — 须核实
""")


# ── 通用搜索 ─────────────────────────────────────────

def cmd_search(queries: list[str]):
    query = " ".join(queries)
    print(f"─── 通用搜索: {query} ───\n")
    cmd_law(queries)
    print()
    cmd_cases(queries)


# ── MCP 配置 ─────────────────────────────────────────

def cmd_mcp_config():
    config = {
        "mcpServers": {
            "gcl-law": {
                "command": sys.argv[0] if sys.argv[0] != "" else "gcl",
                "args": ["law"],
                "description": "中国法律法规查询",
            },
            "gcl-cases": {
                "command": sys.argv[0] if sys.argv[0] != "" else "gcl",
                "args": ["cases"],
                "description": "中国法律案例检索",
            },
            "gcl-verify": {
                "command": sys.argv[0] if sys.argv[0] != "" else "gcl",
                "args": ["verify"],
                "description": "法条效力验证",
            },
        }
    }
    print(json.dumps(config, ensure_ascii=False, indent=2))
    print()
    print("# 复制到 ~/.claude/.mcp.json 后:")
    print("#   /gcl:law 民法典第585条")
    print("#   /gcl:cases 合同纠纷 违约金")


# ── 配置初始化 ───────────────────────────────────────

def cmd_init(force: bool = False):
    if CONFIG_FILE.exists() and not force:
        print(f"配置文件已存在: {CONFIG_FILE}")
        print("使用 --force 重新初始化")
        return
    save_config(DEFAULT_CONFIG)
    print(f"✅ 配置文件: {CONFIG_FILE}")
    print()
    print("数据源:")
    print("  ✅ 国家法律法规数据库 (flk.npc.gov.cn)")
    print("  ✅ web_search 备选")
    print("  ❌ 元典 MCP (须 API key, config 中设置)")
    print("  ❌ 北大法宝 MCP (须 API key, config 中设置)")
    print()
    print("用法: gcl law 民法典第585条")


# ── 入口 ─────────────────────────────────────────────

def main():
    cfg = load_config()

    parser = argparse.ArgumentParser(
        description=f"gcl v{VERSION} — Greater China Legal CLI",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
示例:
  gcl init                    初始化配置
  gcl init --force            重新初始化
  gcl law 民法典第585条       查法条
  gcl cases 合同 违约金       查案例
  gcl verify 民法典 第585条   验证效力
  gcl search 数据出境         通用搜索
  gcl mcp-config              生成 MCP 配置
""",
    )

    sub = parser.add_subparsers(dest="command")

    p_init = sub.add_parser("init", help="初始化配置")
    p_init.add_argument("--force", action="store_true", help="强制重新初始化")

    for name, help_text in [
        ("law", "查询法条文本"),
        ("cases", "查询案例"),
        ("verify", "验证法条效力"),
        ("search", "通用搜索"),
    ]:
        p = sub.add_parser(name, help=help_text)
        p.add_argument("query", nargs="+", help="搜索关键词")

    sub.add_parser("mcp-config", help="输出 MCP server 配置")
    sub.add_parser("sources", help="列出所有数据源")
    sub.add_parser("version", help="版本信息")

    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        return

    cmd_map = {
        "init": lambda: cmd_init(getattr(args, "force", False)),
        "law": lambda: cmd_law(args.query),
        "cases": lambda: cmd_cases(args.query),
        "verify": lambda: cmd_verify(args.query),
        "search": lambda: cmd_search(args.query),
        "mcp-config": cmd_mcp_config,
        "sources": cmd_sources,
        "version": lambda: print(f"gcl v{VERSION} — Config: {CONFIG_FILE}"),
    }

    cmd = cmd_map.get(args.command)
    if cmd:
        cmd()


if __name__ == "__main__":
    main()
